{
  "name": "claude-tray-notifier",
  "version": "1.3.0",
  "description": "macOS menu bar notifier for Claude Code CLI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test 'test/**/*.test.js'",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg",
    "build:dir": "electron-builder --mac dir"
  },
  "build": {
    "appId": "ca.pezant.claude-tray-notifier",
    "productName": "Claude Tray Notifier",
    "publish": {
      "provider": "generic",
      "url": "https://example.com/downloads/"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "files": [
      "main.js",
      "preload.js",
      "preload-session.js",
      "renderer.js",
      "session-renderer.js",
      "index.html",
      "session-detail.html",
      "lib/**",
      "assets/**"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "menubar": "^5.2.3"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  }
}
